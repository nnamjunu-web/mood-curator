# .env.example — 환경변수 템플릿 (이 파일을 복사해 .env 로 만들고 실제 키를 채우세요)
#
# Vite 규칙: 브라우저(클라이언트)에서 읽을 환경변수는 반드시 VITE_ 로 시작해야 한다.
#            코드에서는 import.meta.env.VITE_XXX 로 읽는다.
# 주의: 여기 적는 키는 빌드 결과물에 그대로 노출된다 → "공개해도 되는" 키만 사용할 것.

# TMDB (영화) — https://www.themoviedb.org/settings/api 에서 발급
VITE_TMDB_API_KEY=

# Last.fm (음악) — https://www.last.fm/api/account/create 에서 발급
VITE_LASTFM_API_KEY=

# 도서는 Open Library(openlibrary.org)를 사용하며 API 키가 필요 없습니다.
